# ===========================================
# Ecowitt Weather Station - Configuration
# ===========================================
# Copy this file to .env and fill in your values

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
DEBUG=false

# Public web port for the dashboard (single public entrypoint)
WEB_PORT=8080

# InfluxDB Configuration
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=your-influxdb-token-here
INFLUXDB_ORG=weather
INFLUXDB_BUCKET=ecowitt
# Credenciales del UI de InfluxDB. Solo se aplican en la PRIMERA inicialización
# (volumen vacío). Cámbialas aquí antes del primer arranque; en un despliegue ya
# inicializado, rotarlas requiere el CLI de influx.
INFLUXDB_INIT_USERNAME=admin
INFLUXDB_INIT_PASSWORD=change-me-influx

# MQTT Configuration (optional, for Home Assistant)
MQTT_ENABLED=false
MQTT_BROKER=192.168.1.100
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=weather/ecowitt

# Home Assistant Discovery
HASS_DISCOVERY=true
HASS_DISCOVERY_PREFIX=homeassistant

# Unit System
# Options: metric, imperial
OUTPUT_UNIT_SYSTEM=metric

# Estaciones secundarias (solo lectura). Un GW1100 u otra estación que envíe al
# mismo VPS. Mapa "passkey:nombre" separado por comas, p. ej.
#   SECONDARY_STATIONS=A1B2C3...D6:gw1100
# El passkey se obtiene del log del receiver al apuntar la estación al VPS.
# Cualquier passkey NO listado se trata como la estación principal.
# Las secundarias NO disparan alertas ni publican a redes públicas.
SECONDARY_STATIONS=

# Data Retention (días). 0 = infinita (recomendado: conserva el histórico
# climatológico —records, NOAA anual, "en este día"— que vive en weather_daily).
# El dato es muy comprimible (~50-100 MB/año), así que rara vez conviene limitarlo.
# OJO: este valor solo aplica al CREAR el bucket. Para cambiar uno existente:
#   influx bucket update --id <bucket_id> --retention <0|Xd> -t <TOKEN>
DATA_RETENTION_DAYS=0

# Backups fuera del VPS: subida a Cloudflare R2 (opcional).
# Si se dejan vacíos, el backup solo es local. Requiere rclone instalado.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PREFIX=influx
R2_KEEP=30

# Alerts (optional)
ALERTS_ENABLED=false
ALERT_TEMP_HIGH=35
ALERT_TEMP_LOW=0
ALERT_WIND_HIGH=50
ALERT_GUST_HIGH=70
ALERT_RAIN_RATE=10
ALERT_RAIN_DAILY=40
ALERT_PRESSURE_HIGH=1030
ALERT_PRESSURE_LOW=1000
# Avisar si la estación deja de enviar datos por N minutos
ALERT_STATION_OFFLINE_MINUTES=15
# Avisos de batería baja y sensor sin contacto
ALERT_BATTERY_ENABLED=true
ALERT_SENSOR_LOST_ENABLED=true

# Telegram Notifications (optional)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Calidad del aire (WAQI / aqicn.org) - token gratuito en aqicn.org/data-platform/token
WAQI_TOKEN=

# Panel de administración (usuario/contraseña). Si se dejan vacíos, el panel queda deshabilitado.
ADMIN_USER=
ADMIN_PASSWORD=
# Recomendado: en vez de ADMIN_PASSWORD en claro, usa un hash PBKDF2 (tiene
# prioridad si está definido). Genera el hash con:
#   docker compose exec receiver python -c "from app.services.admin import hash_password; print(hash_password('MI_PASSWORD'))"
# Pega el resultado aquí y deja ADMIN_PASSWORD vacío.
ADMIN_PASSWORD_HASH=

# Grafana (solo con --profile grafana). Cambia la contraseña por defecto.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana

# ---- Mejoras inspiradas en WeeWX ----
# (todo esto también se edita en caliente desde el panel /pro/admin)

# Control de calidad: descarta lecturas fuera de rango antes de guardar
QC_ENABLED=true
# Filtro de picos: descarta saltos imposibles entre lecturas consecutivas
QC_SPIKE_ENABLED=true

# Calibración de sensores (offsets se suman; multiplicadores escalan; 1.0 = sin cambio)
CAL_ENABLED=false
CAL_TEMP_OFFSET=0.0
CAL_HUMIDITY_OFFSET=0.0
CAL_PRESSURE_OFFSET=0.0
CAL_WIND_MULT=1.0
CAL_RAIN_MULT=1.0

# Publicar a redes públicas
WU_ENABLED=false
WU_STATION_ID=
WU_STATION_KEY=
PWS_ENABLED=false
PWS_STATION_ID=
PWS_PASSWORD=
WINDY_ENABLED=false
WINDY_API_KEY=
OWM_ENABLED=false
OWM_API_KEY=
OWM_STATION_ID=
# CWOP / APRS (entra a MADIS -> modelos de NOAA). passcode -1 para designadores CWxxxx.
CWOP_ENABLED=false
CWOP_CALLSIGN=
CWOP_PASSCODE=-1
CWOP_LATITUDE=19.380359
CWOP_LONGITUDE=-99.174564

# Timezone
TZ=America/Mexico_City
# Offset en horas respecto a UTC (para /api/display, ej: -6 para México Central)
TIMEZONE_OFFSET=-6
