# Caddy reverse proxy para el dashboard, detrás de Cloudflare (Orange Cloud).
#
# Con el proxy de Cloudflare activo, el certificado PÚBLICO lo pone Cloudflare
# en el borde. Caddy solo cifra el tramo Cloudflare -> origin usando un
# "Origin Certificate" de Cloudflare (SSL/TLS mode: Full (strict)).
#
# Coloca los archivos del Origin Certificate en caddy/certs/ (no se versionan):
#   caddy/certs/origin.pem   (certificado)
#   caddy/certs/origin.key   (llave privada)

clima.xe1e.net {
	tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key
	encode gzip

	# Headers de seguridad (aplican al tráfico HTTPS de navegadores).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Anti-clickjacking SOLO en el panel admin (evita que se incruste en un
	# iframe malicioso). No se aplica globalmente porque el widget /embed y el
	# kiosko SÍ deben poder incrustarse en otros sitios.
	@admin path /admin /admin/* /pro/admin /pro/admin/*
	header @admin X-Frame-Options "DENY"

	reverse_proxy dashboard:80
}

# --- ALTERNATIVA sin Cloudflare (DNS "grey cloud" / solo DNS) ---
# Si desactivas el proxy de Cloudflare, comenta el bloque de arriba y usa este,
# que obtiene un certificado Let's Encrypt automático por HTTP-01:
#
# clima.xe1e.net {
# 	encode gzip
# 	reverse_proxy dashboard:80
# }
#
# NOTA: el WS2910 hace push por HTTP a la IP:8080 directamente
# (http://163.192.147.208:8080/data/report/), se salta Cloudflare. Los
# navegadores y Home Assistant usan https://clima.xe1e.net.
